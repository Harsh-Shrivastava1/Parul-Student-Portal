# ─── Student Portal frontend (Vite) ───────────────────────────────────────────
# Each business domain is served by its OWNER backend. The Student URL has a
# safe default; the TEC and Coordinator URLs are REQUIRED (no silent fallback) —
# a call to an unconfigured backend fails fast with a clear error.

# Student Portal backend (auth, profile, me/*, read gateways, notifications)
VITE_STUDENT_API_URL=http://localhost:5002/api

# TEC Cell backend — REQUIRED for application writes (apply / withdraw) and
# document downloads (Application PDF / Offer Letter / Completion Certificate).
VITE_TEC_API_URL=http://localhost:4000/api

# Coordinator backend — REQUIRED for the Attendance Form download (the
# Coordinator owns + serves that file).
VITE_COORDINATOR_API_URL=http://localhost:5001/api
