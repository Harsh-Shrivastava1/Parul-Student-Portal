# ─── Student Portal Backend — PRODUCTION template ─────────────────────────────
# Copy to `.env` and fill real values. NEVER commit `.env` or real secrets.
PORT=5002
NODE_ENV=production

# ─── MongoDB Atlas (shared cluster; DB = internship_management) ───────────────
# Use the SRV string from Atlas. Keep <USERNAME>/<PASSWORD> as real values only
# in the local .env — never in this template or any commit.
MONGODB_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=internship_management

# ─── JWT (REQUIRED — server refuses to start if missing; no defaults) ─────────
# Generate each with:  openssl rand -hex 32
# ‼ JWT_ACCESS_SECRET is the SHARED student secret: it MUST EXACTLY equal the
#   TEC backend's STUDENT_JWT_ACCESS_SECRET and the Coordinator backend's
#   STUDENT_JWT_ACCESS_SECRET (they verify student tokens with it).
JWT_ACCESS_SECRET=<GENERATE_openssl_rand_hex_32__SHARED_WITH_TEC_AND_COORDINATOR>
JWT_REFRESH_SECRET=<GENERATE_openssl_rand_hex_32>
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
BCRYPT_ROUNDS=12

# ─── CORS: allowed frontend origins (comma-separated, exact, no wildcard) ─────
FRONTEND_ORIGINS=https://student.<your-domain>

# ─── Cookie strategy ──────────────────────────────────────────────────────────
# Same-site deploy (SPA + API same registrable domain): keep strict.
# Cross-site deploy (SPA and API on different domains): SameSite must be None +
#   Secure to be sent cross-site → set COOKIE_SAMESITE=none (forces Secure).
# (Cookie path is fixed to '/'; COOKIE_DOMAIN is not read by the code.)
COOKIE_SAMESITE=strict
COOKIE_SECURE=true

# ─── Email (Gmail SMTP) — optional/graceful ──────────────────────────────────
# Shared mailbox across all portals. With no SMTP_HOST the mailer falls back to
# an Ethereal test inbox (preview URLs only) and never blocks startup.
# SMTP_PASS is a Gmail App Password (not the account password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<gmail-address>
SMTP_PASS=<gmail-app-password>
EMAIL_FROM="Internship Management System <gmail-address>"
